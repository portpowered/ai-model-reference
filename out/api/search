xonomy"],"url":"/docs/glossary/encoder"},"382":{"id":"/docs/glossary/encoder-0","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"A network stack that maps raw or patched inputs into internal representations—tokens, latents, or context vectors—for downstream decoders or heads."},"383":{"id":"/docs/glossary/encoder-1","page_id":"/docs/glossary/encoder","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/encoder#heading-0","content":"Encoder"},"384":{"id":"/docs/glossary/encoder-2","page_id":"/docs/glossary/encoder","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/encoder#heading-1","content":"What It Is"},"385":{"id":"/docs/glossary/encoder-3","page_id":"/docs/glossary/encoder","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/encoder#heading-2","content":"Why It Matters"},"386":{"id":"/docs/glossary/encoder-4","page_id":"/docs/glossary/encoder","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/encoder#heading-3","content":"Simple Example"},"387":{"id":"/docs/glossary/encoder-5","page_id":"/docs/glossary/encoder","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/encoder#heading-4","content":"Where It Appears"},"388":{"id":"/docs/glossary/encoder-6","page_id":"/docs/glossary/encoder","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/encoder#heading-5","content":"Common Confusions"},"389":{"id":"/docs/glossary/encoder-7","page_id":"/docs/glossary/encoder","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/encoder#heading-6","content":"Related Concepts And Modules"},"390":{"id":"/docs/glossary/encoder-8","page_id":"/docs/glossary/encoder","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/encoder#heading-7","content":"Tags"},"391":{"id":"/docs/glossary/encoder-9","page_id":"/docs/glossary/encoder","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/encoder#heading-8","content":"References"},"392":{"id":"/docs/glossary/encoder-10","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder#Encoder","content":"A network stack that maps raw or patched inputs into internal representations—tokens, latents, or context vectors—for downstream decoders or heads.\n\nEncoder\nA network stack that maps raw or patched inputs into internal representations—tokens, latents, or context vectors—for downstream decoders or heads.\nAn encoder ingests modality-specific input units—tokens, patches, or frames—and outputs structured representations that later blocks consume for decoding or prediction.\nWhat It Is\nEncoders appear as transformer stacks over patch embeddings, convolutional towers before a latent bottleneck, or BERT-style bidirectional encoders that emit contextual vectors per token. The output is always an internal representation: not logits and not final generated pixels or text unless a head is attached directly.\nWhy It Matters\nSeparating encoders from decoders clarifies seq2seq translation, multimodal fusion, and diffusion pipelines where one network fills latent space and another reads it out. It also explains why representation, patch, and latent-space glossary entries sit upstream of architecture family pages.\nSimple Example\nA ViT encoder turns 196 image patch embeddings into 196 contextual vectors; a translation encoder turns source-language tokens into memory vectors that a decoder attends to when generating the target sentence.\nWhere It Appears\nEncoders headline encoder–decoder translation models, CLIP-style dual towers, VAE and diffusion front ends, and discriminative classifiers that only need a pooled representation. Decoder and encoder–decoder pages describe how those representations are consumed or recombined.\nCommon Confusions\nAn encoder is not the same as the full model: decoder-only language models still contain transformer blocks, but the name encoder usually marks the input-side stack in a split architecture. An encoder is also not a tokenizer—tokenization is discrete indexing; the encoder operates on embeddings or patches after that step.\nRelated Concepts And Modules\nTags\nReferences\nReader Shortcut\nTrace the arrow from raw input to the first representation tensor—that stack is the encoder story, regardless of modality."},"393":{"id":"/docs/glossary/encoder-11","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"Encoder"},"394":{"id":"/docs/glossary/encoder-12","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"encoder block"},"395":{"id":"/docs/glossary/encoder-13","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"encoder stack"},"396":{"id":"/docs/glossary/encoder-14","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"encoding network"},"397":{"id":"/docs/glossary/encoder-15","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"foundations"},"398":{"id":"/docs/glossary/encoder-16","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"foundational concepts"},"399":{"id":"/docs/glossary/encoder-17","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"phase 2 foundations"},"400":{"id":"/docs/glossary/encoder-18","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"core vocabulary"},"401":{"id":"/docs/glossary/encoder-19","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"taxonomy"},"402":{"id":"/docs/glossary/encoder-20","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"glossary taxonomy"},"403":{"id":"/docs/glossary/encoder-21","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"atlas taxonomy"},"404":{"id":"/docs/glossary/encoder-22","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"taxonomy glossary"},"405":{"id":"/docs/glossary/encoder-23","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"cross-family taxonomy"},"406":{"id":"/docs/glossary/encoder-24","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"foundations"},"407":{"id":"/docs/glossary/encoder-25","page_id":"/docs/glossary/encoder","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/encoder","content":"taxonomy"},"408":{"id":"/docs/glossary/scaling-law","page_id":"/docs/glossary/scaling-law","type":"page","content":"Scaling Law","tags":["foundations","taxonomy"],"url":"/docs/glossary/scaling-law"},"409":{"id":"/docs/glossary/scaling-law-0","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"Empirical power-law relationships between model scale, compute, data, and downstream loss or capability—used to forecast training budgets and benchmark trends."},"410":{"id":"/docs/glossary/scaling-law-1","page_id":"/docs/glossary/scaling-law","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/scaling-law#heading-0","content":"Scaling Law"},"411":{"id":"/docs/glossary/scaling-law-2","page_id":"/docs/glossary/scaling-law","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/scaling-law#heading-1","content":"What It Is"},"412":{"id":"/docs/glossary/scaling-law-3","page_id":"/docs/glossary/scaling-law","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/scaling-law#heading-2","content":"Why It Matters"},"413":{"id":"/docs/glossary/scaling-law-4","page_id":"/docs/glossary/scaling-law","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/scaling-law#heading-3","content":"Simple Example"},"414":{"id":"/docs/glossary/scaling-law-5","page_id":"/docs/glossary/scaling-law","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/scaling-law#heading-4","content":"Where It Appears"},"415":{"id":"/docs/glossary/scaling-law-6","page_id":"/docs/glossary/scaling-law","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/scaling-law#heading-5","content":"Common Confusions"},"416":{"id":"/docs/glossary/scaling-law-7","page_id":"/docs/glossary/scaling-law","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/scaling-law#heading-6","content":"Related Concepts And Modules"},"417":{"id":"/docs/glossary/scaling-law-8","page_id":"/docs/glossary/scaling-law","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/scaling-law#heading-7","content":"Tags"},"418":{"id":"/docs/glossary/scaling-law-9","page_id":"/docs/glossary/scaling-law","type":"heading","tags":["foundations","taxonomy"],"url":"/docs/glossary/scaling-law#heading-8","content":"References"},"419":{"id":"/docs/glossary/scaling-law-10","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law#Scaling Law","content":"Empirical power-law relationships between model scale, compute, data, and downstream loss or capability—used to forecast training budgets and benchmark trends.\n\nScaling Law\nEmpirical power-law relationships between model scale, compute, data, and downstream loss or capability—used to forecast training budgets and benchmark trends.\nScaling laws describe predictable loss improvements when model size, dataset size, or compute increase along a training frontier, often as power laws until limits bend the curve.\nWhat It Is\nA scaling law is an empirical fit relating scale (parameters, training tokens, or compute) to a target such as validation loss or perplexity. Kaplan-style language-model laws showed smooth improvements over many orders of magnitude when training is near-optimal. The relationship is descriptive—not a guarantee that every architecture or objective follows the same exponents.\nWhy It Matters\nScaling laws help forecast whether a larger run is worth the budget and how much data a parameter count needs. They tie evaluation metrics to capacity: model capacity and parameter count set the frontier, generalization and perplexity track whether the run landed on it, and emergent behavior pages describe capabilities that may not appear on the same smooth curve.\nSimple Example\nIf doubling parameters cuts validation loss by a fixed fraction on a log-log plot across several sizes, you can extrapolate the next checkpoint’s expected perplexity before paying for the full training run—until the data-limited regime flattens the trend.\nWhere It Appears\nScaling papers, compute-optimal training recipes (Chinchilla-style tradeoffs), and roadmap slides comparing parameter counts. Architecture and model-capacity pages explain what is being scaled; perplexity and generalization pages show the measured outcomes.\nCommon Confusions\nA scaling law is not the same as emergent behavior—many metrics improve smoothly while specific capabilities appear abruptly. Laws fit historical runs; they do not remove the need for held-out evaluation or alignment checks on new tasks.\nRelated Concepts And Modules\nTags\nReferences\nReader Shortcut\nAsk which axis was scaled (params, data, compute) and which metric was fit before trusting an extrapolation."},"420":{"id":"/docs/glossary/scaling-law-11","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"Scaling law"},"421":{"id":"/docs/glossary/scaling-law-12","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"scaling laws"},"422":{"id":"/docs/glossary/scaling-law-13","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"power-law scaling"},"423":{"id":"/docs/glossary/scaling-law-14","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"compute scaling"},"424":{"id":"/docs/glossary/scaling-law-15","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"foundations"},"425":{"id":"/docs/glossary/scaling-law-16","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"foundational concepts"},"426":{"id":"/docs/glossary/scaling-law-17","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"phase 2 foundations"},"427":{"id":"/docs/glossary/scaling-law-18","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"core vocabulary"},"428":{"id":"/docs/glossary/scaling-law-19","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"taxonomy"},"429":{"id":"/docs/glossary/scaling-law-20","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"glossary taxonomy"},"430":{"id":"/docs/glossary/scaling-law-21","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"atlas taxonomy"},"431":{"id":"/docs/glossary/scaling-law-22","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"taxonomy glossary"},"432":{"id":"/docs/glossary/scaling-law-23","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"cross-family taxonomy"},"433":{"id":"/docs/glossary/scaling-law-24","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"foundations"},"434":{"id":"/docs/glossary/scaling-law-25","page_id":"/docs/glossary/scaling-law","tags":["foundations","taxonomy"],"type":"text","url":"/docs/glossary/scaling-law","content":"taxonomy"},"435":{"id":"/docs/glossary/transformer","page_id":"/docs/glossary/transformer","type":"page","content":"Transformer","tags":["taxonomy","model-family"],"url":"/docs/glossary/transformer"},"436":{"id":"/docs/glossary/transformer-0","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"A model family built from stacked attention and feed-forward blocks that mix information across token positions in parallel."},"437":{"id":"/docs/glossary/transformer-1","page_id":"/docs/glossary/transformer","type":"heading","tags":["taxonomy","model-family"],"url":"/docs/glossary/transformer#heading-0","content":"Transformer"},"438":{"id":"/docs/glossary/transformer-2","page_id":"/docs/glossary/transformer","type":"heading","tags":["taxonomy","model-family"],"url":"/docs/glossary/transformer#heading-1","content":"What It Is"},"439":{"id":"/docs/glossary/transformer-3","page_id":"/docs/glossary/transformer","type":"heading","tags":["taxonomy","model-family"],"url":"/docs/glossary/transformer#heading-2","content":"Why It Matters"},"440":{"id":"/docs/glossary/transformer-4","page_id":"/docs/glossary/transformer","type":"heading","tags":["taxonomy","model-family"],"url":"/docs/glossary/transformer#heading-3","content":"Simple Example"},"441":{"id":"/docs/glossary/transformer-5","page_id":"/docs/glossary/transformer","type":"heading","tags":["taxonomy","model-family"],"url":"/docs/glossary/transformer#heading-4","content":"Common Confusions"},"442":{"id":"/docs/glossary/transformer-6","page_id":"/docs/glossary/transformer","type":"heading","tags":["taxonomy","model-family"],"url":"/docs/glossary/transformer#heading-5","content":"Related Concepts And Modules"},"443":{"id":"/docs/glossary/transformer-7","page_id":"/docs/glossary/transformer","type":"heading","tags":["taxonomy","model-family"],"url":"/docs/glossary/transformer#heading-6","content":"Tags"},"444":{"id":"/docs/glossary/transformer-8","page_id":"/docs/glossary/transformer","type":"heading","tags":["taxonomy","model-family"],"url":"/docs/glossary/transformer#heading-7","content":"References"},"445":{"id":"/docs/glossary/transformer-9","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer#Transformer","content":"A model family built from stacked attention and feed-forward blocks that mix information across token positions in parallel.\n\nTransformer\nA model family built from stacked attention and feed-forward blocks that mix information across token positions in parallel.\nTransformers stack attention and feed-forward blocks so each token position can gather context from others in one parallel pass—causal in decoders, bidirectional in many encoders—before a head emits logits or cross-attends into another stack.\nWhat It Is\nA transformer repeats blocks of self-attention (or cross-attention in encoder–decoder setups) followed by position-wise feed-forward networks. Token embeddings enter the stack; each block updates hidden representations for every position. Decoder-only stacks use causal attention masks; encoder stacks can attend bidirectionally. The family name describes this block recipe, not any single checkpoint.\nWhy It Matters\nTransformers dominate language, code, and many multimodal systems because attention scales flexibly with sequence length and parallelizes well on accelerators. Knowing the family separates architecture choices—decoder-only versus encoder–decoder, grouped-query attention for decoding—from training data or product packaging. The architecture page situates transformers among other families; this page is the dedicated reference for the block stack itself.\nSimple Example\nA decoder-only transformer for chat embeds each prompt token, runs twelve identical blocks of causal self-attention plus MLP, then projects the final hidden state to vocabulary logits for the next token. GPT-2, Llama, and many instruction-tuned models share that loop even when layer counts and widths differ.\nCommon Confusions\nTransformer is a model family and architecture pattern, not a synonym for large language model: many LLMs use transformers, but so do smaller classifiers and speech models. Attention is a module inside transformer blocks, not the whole family. Transformer also differs from autoregressive generation: the family describes the network; autoregressive generation describes the step-by-step decoding loop often run on decoder stacks.\nRelated Concepts And Modules\nTags\nReferences"},"446":{"id":"/docs/glossary/transformer-10","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"Transformers"},"447":{"id":"/docs/glossary/transformer-11","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"transformer model"},"448":{"id":"/docs/glossary/transformer-12","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"transformer architecture"},"449":{"id":"/docs/glossary/transformer-13","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"taxonomy"},"450":{"id":"/docs/glossary/transformer-14","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"glossary taxonomy"},"451":{"id":"/docs/glossary/transformer-15","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"atlas taxonomy"},"452":{"id":"/docs/glossary/transformer-16","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"taxonomy glossary"},"453":{"id":"/docs/glossary/transformer-17","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"cross-family taxonomy"},"454":{"id":"/docs/glossary/transformer-18","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"model-family"},"455":{"id":"/docs/glossary/transformer-19","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"model families"},"456":{"id":"/docs/glossary/transformer-20","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"architecture families"},"457":{"id":"/docs/glossary/transformer-21","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"model family"},"458":{"id":"/docs/glossary/transformer-22","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"taxonomy"},"459":{"id":"/docs/glossary/transformer-23","page_id":"/docs/glossary/transformer","tags":["taxonomy","model-family"],"type":"text","url":"/docs/glossary/transformer","content":"model-family"},"460":{"id":"/docs/glossary/module","page_id":"/docs/glossary/module","type":"page","content":"Module","tags":["taxonomy","foundations"],"url":"/docs/glossary/module"},"461":{"id":"/docs/glossary/module-0","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"A reusable building block inside a model architecture, such as attention or a feed-forward network."},"462":{"id":"/docs/glossary/module-1","page_id":"/docs/glossary/module","type":"heading","tags":["taxonomy","foundations"],"url":"/docs/glossary/module#heading-0","content":"Module"},"463":{"id":"/docs/glossary/module-2","page_id":"/docs/glossary/module","type":"heading","tags":["taxonomy","foundations"],"url":"/docs/glossary/module#heading-1","content":"What It Is"},"464":{"id":"/docs/glossary/module-3","page_id":"/docs/glossary/module","type":"heading","tags":["taxonomy","foundations"],"url":"/docs/glossary/module#heading-2","content":"Why It Matters"},"465":{"id":"/docs/glossary/module-4","page_id":"/docs/glossary/module","type":"heading","tags":["taxonomy","foundations"],"url":"/docs/glossary/module#heading-3","content":"Simple Example"},"466":{"id":"/docs/glossary/module-5","page_id":"/docs/glossary/module","type":"heading","tags":["taxonomy","foundations"],"url":"/docs/glossary/module#heading-4","content":"Where It Appears"},"467":{"id":"/docs/glossary/module-6","page_id":"/docs/glossary/module","type":"heading","tags":["taxonomy","foundations"],"url":"/docs/glossary/module#heading-5","content":"Common Confusions"},"468":{"id":"/docs/glossary/module-7","page_id":"/docs/glossary/module","type":"heading","tags":["taxonomy","foundations"],"url":"/docs/glossary/module#heading-6","content":"Related Concepts And Modules"},"469":{"id":"/docs/glossary/module-8","page_id":"/docs/glossary/module","type":"heading","tags":["taxonomy","foundations"],"url":"/docs/glossary/module#heading-7","content":"Tags"},"470":{"id":"/docs/glossary/module-9","page_id":"/docs/glossary/module","type":"heading","tags":["taxonomy","foundations"],"url":"/docs/glossary/module#heading-8","content":"References"},"471":{"id":"/docs/glossary/module-10","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module#Module","content":"A reusable building block inside a model architecture, such as attention or a feed-forward network.\n\nModule\nA reusable building block inside a model architecture, such as attention or a feed-forward network.\nA module is a named, reusable unit of computation that an architecture stacks or wires together into a full model.\nWhat It Is\nModules are the mid-level parts of a network: multi-head attention, grouped-query attention, convolution blocks, or cross-attention layers. An architecture describes how modules connect; module pages explain one mechanism in depth.\nWhy It Matters\nSearching by module helps you compare attention variants across models and spot when a release swaps one module for another without changing the overall architecture family.\nSimple Example\nA transformer block is often drawn as two modules in sequence: self-attention, then a position-wise feed-forward network. Each can be swapped—for example, GQA instead of MHA—while keeping the block shape.\nWhere It Appears\nModule is the label for `/docs/modules/*` entries and for internal registry records tied to those pages. Components sit inside modules when you need finer-grained structure.\nCommon Confusions\nA module is larger than a component (heads, projections) but smaller than a full architecture. It is also not a trained model: modules are design patterns; checkpoints combine many module weights.\nRelated Concepts And Modules\nTags\nReferences\nReader Shortcut\nIf the docs route starts with `/docs/modules/`, you are reading about a specific module implementation—not the abstract taxonomy term on this page."},"472":{"id":"/docs/glossary/module-11","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"model module"},"473":{"id":"/docs/glossary/module-12","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"building block"},"474":{"id":"/docs/glossary/module-13","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"network module"},"475":{"id":"/docs/glossary/module-14","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"taxonomy"},"476":{"id":"/docs/glossary/module-15","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"glossary taxonomy"},"477":{"id":"/docs/glossary/module-16","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"atlas taxonomy"},"478":{"id":"/docs/glossary/module-17","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"taxonomy glossary"},"479":{"id":"/docs/glossary/module-18","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"cross-family taxonomy"},"480":{"id":"/docs/glossary/module-19","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"foundations"},"481":{"id":"/docs/glossary/module-20","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"foundational concepts"},"482":{"id":"/docs/glossary/module-21","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"phase 2 foundations"},"483":{"id":"/docs/glossary/module-22","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"core vocabulary"},"484":{"id":"/docs/glossary/module-23","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"taxonomy"},"485":{"id":"/docs/glossary/module-24","page_id":"/docs/glossary/module","tags":["taxonomy","foundations"],"type":"text","url":"/docs/glossary/module","content":"foundations"},"486":{"id":"/docs/glossary/optimizer-state","page_id":"/docs/glossary/optimizer-state","type":"page","content":"Optimizer State","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/optimizer-state"},"487":{"id":"/docs/glossary/optimizer-state-0","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/optimizer-state","content":"Extra memory an adaptive optimizer keeps beyond model weights, such as momentum and variance estimates for each parameter."},"488":{"id":"/docs/glossary/optimizer-state-1","page_id":"/docs/glossary/optimizer-state","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/optimizer-state#heading-0","content":"Optimizer State"},"489":{"id":"/docs/glossary/optimizer-state-2","page_id":"/docs/glossary/optimizer-state","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/optimizer-state#heading-1","content":"What It Is"},"490":{"id":"/docs/glossary/optimizer-state-3","page_id":"/docs/glossary/optimizer-state","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/optimizer-state#heading-2","content":"Why It Matters"},"491":{"id":"/docs/glossary/optimizer-state-4","page_id":"/docs/glossary/optimizer-state","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/optimizer-state#heading-3","content":"Simple Example"},"492":{"id":"/docs/glossary/optimizer-state-5","page_id":"/docs/glossary/optimizer-state","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/optimizer-state#heading-4","content":"Where It Appears"},"493":{"id":"/docs/glossary/optimizer-state-6","page_id":"/docs/glossary/optimizer-state","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/optimizer-state#heading-5","content":"Common Confusions"},"494":{"id":"/docs/glossary/optimizer-state-7","page_id":"/docs/glossary/optimizer-state","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/optimizer-state#heading-6","content":"Related Concepts And Modules"},"495":{"id":"/docs/glossary/optimizer-state-8","page_id":"/docs/glossary/optimizer-state","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/optimizer-state#heading-7","content":"Tags"},"496":{"id":"/docs/glossary/optimizer-state-9","page_id":"/docs/glossary/optimizer-state","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/optimizer-state#heading-8","content":"References"},"497":{"id":"/docs/glossary/optimizer-state-10","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/optimizer-state#Optimizer State","content":"Extra memory an adaptive optimizer keeps beyond model weights, such as momentum and variance estimates for each parameter.\n\nOptimizer State\nExtra memory an adaptive optimizer keeps beyond model weights, such as momentum and variance estimates for each parameter.\nOptimizer state stores per-parameter running history used to shape each update—distinct from the weights themselves and required for faithful training resumes.\nWhat It Is\nModel parameters hold the learned weights, but adaptive optimizers also keep auxiliary tensors aligned with each parameter shape. Adam tracks exponential moving averages of gradients and squared gradients (often called m and v). Momentum methods keep velocity buffers. These tensors are optimizer state: they are updated every step and influence the effective learning rate per parameter.\nWhy It Matters\nSaving only model weights and reloading into a fresh optimizer resets training dynamics—you lose accumulated momentum and adaptive scaling. Large-language-model training checkpoints therefore include optimizer state, which can be several times the parameter memory footprint. Inference-only deployments usually discard optimizer state because weights alone are enough to run forward passes.\nSimple Example\nWith Adam, each weight w might have companion buffers m_w and v_w. On step t the optimizer reads gradient g_w, updates m_w and v_w with decay factors β₁ and β₂, then applies a scaled step to w. Those buffers—not the gradient from the current batch alone—determine how large the update is.\nWhere It Appears\nPyTorch `optimizer.state_dict()`, DeepSpeed ZeRO sharding, and Hugging Face Trainer checkpoints all persist optimizer buffers alongside weights. Distinctive chain phrase: Adam first and second moment buffers per parameter tensor.\nCommon Confusions\nOptimizer state is not the same as model parameters or gradients—parameters are what you learn, gradients are ephemeral signals from the current backward pass, and optimizer state is long-lived memory across steps. It also differs from activation checkpoints or KV cache used during inference. Mixing up optimizer state with EMA shadow weights (used in some eval setups) causes confusion when comparing checkpoint sizes.\nRelated Concepts And Modules\nTags\nReferences\nReader Shortcut\nParameters are the weights; gradients say how to change them this step; optimizer state remembers past steps so updates stay stable and adaptive."},"498":{"id":"/docs/glossary/optimizer-state-11","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/optimizer-state","content":"optimizer state"},"499":{"id":"/docs/glossary/optimizer-state-12","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/optimizer-state","content":"Adam state"},"500":{"id":"/docs/glossary/optimizer-state-13","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/optimizer-state","content":"momentum buffers"},"501":{"id":"/docs/glossary/optimizer-state-14","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/optimizer-state","content":"token-to-probability-chain"},"502":{"id":"/docs/glossary/optimizer-state-15","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/optimizer-state","content":"token to probability chain"},"503":{"id":"/docs/glossary/optimizer-state-16","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/optimizer-state","content":"phase 2 probability chain"},"504":{"id":"/docs/glossary/optimizer-state-17","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/optimizer-state","content":"foundations probability path"},"505":{"id":"/docs/glossary/optimizer-state-18","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/optimizer-state","content":"foundations"},"506":{"id":"/docs/glossary/optimizer-state-19","page_id":"/docs/glossary/optimizer-state","tags":["token-to-probability-chain","foundations"