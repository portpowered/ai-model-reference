s/glossary/entropy","type":"page","content":"Entropy","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/entropy"},"632":{"id":"/docs/glossary/entropy-0","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"A measure of how spread out or uncertain a probability distribution is over next-token choices."},"633":{"id":"/docs/glossary/entropy-1","page_id":"/docs/glossary/entropy","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/entropy#heading-0","content":"Entropy"},"634":{"id":"/docs/glossary/entropy-2","page_id":"/docs/glossary/entropy","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/entropy#heading-1","content":"What It Is"},"635":{"id":"/docs/glossary/entropy-3","page_id":"/docs/glossary/entropy","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/entropy#heading-2","content":"Why It Matters"},"636":{"id":"/docs/glossary/entropy-4","page_id":"/docs/glossary/entropy","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/entropy#heading-3","content":"Simple Example"},"637":{"id":"/docs/glossary/entropy-5","page_id":"/docs/glossary/entropy","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/entropy#heading-4","content":"Where It Appears"},"638":{"id":"/docs/glossary/entropy-6","page_id":"/docs/glossary/entropy","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/entropy#heading-5","content":"Common Confusions"},"639":{"id":"/docs/glossary/entropy-7","page_id":"/docs/glossary/entropy","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/entropy#heading-6","content":"Related Concepts And Modules"},"640":{"id":"/docs/glossary/entropy-8","page_id":"/docs/glossary/entropy","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/entropy#heading-7","content":"Tags"},"641":{"id":"/docs/glossary/entropy-9","page_id":"/docs/glossary/entropy","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/entropy#heading-8","content":"References"},"642":{"id":"/docs/glossary/entropy-10","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy#Entropy","content":"A measure of how spread out or uncertain a probability distribution is over next-token choices.\n\nEntropy\nA measure of how spread out or uncertain a probability distribution is over next-token choices.\nEntropy summarizes a softmax probability vector in one number: low entropy means the model is confident, high entropy means many tokens look equally plausible.\nWhat It Is\nFor a discrete distribution p over vocabulary indices, Shannon entropy counts how many nats (or bits, if you use log base 2) of uncertainty remain in the next-token guess. It is zero only when one token has probability 1.\nWhy It Matters\nMonitoring entropy during decoding shows when the model is hedging versus committing. Researchers compare entropy across layers, prompts, or safety interventions. It pairs naturally with temperature, which deliberately reshapes the same distribution.\nSimple Example\nIf softmax yields [0.7, 0.2, 0.1], entropy is lower than for [0.34, 0.33, 0.33] because the first vector is peaked. Plugging those probabilities into the Shannon formula gives a concrete numeric comparison.\nWhere It Appears\nEvaluation notebooks plot Shannon entropy of the next-token distribution at each decode step. Some sampling dashboards surface entropy alongside top-k mass. Distinctive chain phrase: Shannon entropy of the next-token distribution at decode time.\nCommon Confusions\nEntropy is not the same as cross-entropy loss during training—loss compares predictions to labels, while entropy describes a single distribution on its own. High logit magnitude does not by itself imply low entropy until softmax runs.\nRelated Concepts And Modules\nTags\nReferences\nReader Shortcut\nIf softmax gives you probabilities, entropy tells you how spread out they are—then temperature explains how to dial that spread up or down on purpose."},"643":{"id":"/docs/glossary/entropy-11","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"output entropy"},"644":{"id":"/docs/glossary/entropy-12","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"prediction entropy"},"645":{"id":"/docs/glossary/entropy-13","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"uncertainty"},"646":{"id":"/docs/glossary/entropy-14","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"token-to-probability-chain"},"647":{"id":"/docs/glossary/entropy-15","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"token to probability chain"},"648":{"id":"/docs/glossary/entropy-16","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"phase 2 probability chain"},"649":{"id":"/docs/glossary/entropy-17","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"foundations probability path"},"650":{"id":"/docs/glossary/entropy-18","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"foundations"},"651":{"id":"/docs/glossary/entropy-19","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"foundational concepts"},"652":{"id":"/docs/glossary/entropy-20","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"phase 2 foundations"},"653":{"id":"/docs/glossary/entropy-21","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"core vocabulary"},"654":{"id":"/docs/glossary/entropy-22","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"token-to-probability-chain"},"655":{"id":"/docs/glossary/entropy-23","page_id":"/docs/glossary/entropy","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/entropy","content":"foundations"},"656":{"id":"/docs/glossary/computational-graph","page_id":"/docs/glossary/computational-graph","type":"page","content":"Computational Graph","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/computational-graph"},"657":{"id":"/docs/glossary/computational-graph-0","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/computational-graph","content":"A record of which operations produced each tensor so automatic differentiation can run backward."},"658":{"id":"/docs/glossary/computational-graph-1","page_id":"/docs/glossary/computational-graph","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/computational-graph#heading-0","content":"Computational Graph"},"659":{"id":"/docs/glossary/computational-graph-2","page_id":"/docs/glossary/computational-graph","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/computational-graph#heading-1","content":"What It Is"},"660":{"id":"/docs/glossary/computational-graph-3","page_id":"/docs/glossary/computational-graph","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/computational-graph#heading-2","content":"Why It Matters"},"661":{"id":"/docs/glossary/computational-graph-4","page_id":"/docs/glossary/computational-graph","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/computational-graph#heading-3","content":"Simple Example"},"662":{"id":"/docs/glossary/computational-graph-5","page_id":"/docs/glossary/computational-graph","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/computational-graph#heading-4","content":"Where It Appears"},"663":{"id":"/docs/glossary/computational-graph-6","page_id":"/docs/glossary/computational-graph","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/computational-graph#heading-5","content":"Common Confusions"},"664":{"id":"/docs/glossary/computational-graph-7","page_id":"/docs/glossary/computational-graph","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/computational-graph#heading-6","content":"Related Concepts And Modules"},"665":{"id":"/docs/glossary/computational-graph-8","page_id":"/docs/glossary/computational-graph","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/computational-graph#heading-7","content":"Tags"},"666":{"id":"/docs/glossary/computational-graph-9","page_id":"/docs/glossary/computational-graph","type":"heading","tags":["token-to-probability-chain","foundations"],"url":"/docs/glossary/computational-graph#heading-8","content":"References"},"667":{"id":"/docs/glossary/computational-graph-10","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/computational-graph#Computational Graph","content":"A record of which operations produced each tensor so automatic differentiation can run backward.\n\nComputational Graph\nA record of which operations produced each tensor so automatic differentiation can run backward.\nThe computational graph links inputs, parameters, and activations through differentiable ops, and backpropagation walks that graph in reverse to assign credit to each parameter.\nWhat It Is\nDuring a forward pass, frameworks build a directed graph whose nodes are operations (matrix multiply, softmax, loss) and whose edges carry tensors. The graph is the bookkeeping structure autograd uses—not something you usually draw by hand for a full transformer.\nWhy It Matters\nWithout the graph, you would hand-derive a gradient for every layer. With it, the same forward code that produced logits and loss also enables `.backward()` to populate parameter gradients consistently.\nSimple Example\nMultiply embedding weights by a one-hot input, add bias, apply GELU—each step becomes a node. The loss node at the end connects backward to every parameter node that influenced the prediction.\nWhere It Appears\nPyTorch builds a dynamic graph per forward pass; some compilers fuse or rewrite the graph for speed. Debugging NaN losses often starts by inspecting which graph node first produced non-finite values.\nCommon Confusions\nThe computational graph is not the same as the model architecture diagram in a paper—architecture is the human design, while the graph is the runtime trace of differentiable ops for one forward pass. It is also not the optimizer state, which stores update history rather than forward connectivity.\nRelated Concepts And Modules\nTags\nReferences\nReader Shortcut\nOnce you know activations flow forward, think of the computational graph as the map backpropagation follows to turn a loss signal into parameter updates."},"668":{"id":"/docs/glossary/computational-graph-11","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/computational-graph","content":"computation graph"},"669":{"id":"/docs/glossary/computational-graph-12","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/computational-graph","content":"autograd graph"},"670":{"id":"/docs/glossary/computational-graph-13","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/computational-graph","content":"forward graph"},"671":{"id":"/docs/glossary/computational-graph-14","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/computational-graph","content":"token-to-probability-chain"},"672":{"id":"/docs/glossary/computational-graph-15","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/computational-graph","content":"token to probability chain"},"673":{"id":"/docs/glossary/computational-graph-16","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/computational-graph","content":"phase 2 probability chain"},"674":{"id":"/docs/glossary/computational-graph-17","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/computational-graph","content":"foundations probability path"},"675":{"id":"/docs/glossary/computational-graph-18","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":"text","url":"/docs/glossary/computational-graph","content":"foundations"},"676":{"id":"/docs/glossary/computational-graph-19","page_id":"/docs/glossary/computational-graph","tags":["token-to-probability-chain","foundations"],"type":