-cache"],"url":"/docs/modules/multi-head-latent-attention"},"1423":{"id":"/docs/modules/multi-head-latent-attention-0","page_id":"/docs/modules/multi-head-latent-attention","tags":["attention","kv-cache"],"type":"text","url":"/docs/modules/multi-head-latent-attention","content":"An attention variant that compresses key-value cache storage into a low-rank latent space while keeping distinct query heads."},"1424":{"id":"/docs/modules/multi-head-latent-attention-1","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-0","content":"Multi-Head Latent Attention"},"1425":{"id":"/docs/modules/multi-head-latent-attention-2","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-1","content":"What It Is"},"1426":{"id":"/docs/modules/multi-head-latent-attention-3","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-2","content":"What It Optimizes"},"1427":{"id":"/docs/modules/multi-head-latent-attention-4","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-3","content":"Practical Benefit"},"1428":{"id":"/docs/modules/multi-head-latent-attention-5","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-4","content":"How It Works"},"1429":{"id":"/docs/modules/multi-head-latent-attention-6","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-5","content":"Math Or Compute Schema"},"1430":{"id":"/docs/modules/multi-head-latent-attention-7","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-6","content":"Compared To Nearby Modules"},"1431":{"id":"/docs/modules/multi-head-latent-attention-8","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-7","content":"Example Architectures"},"1432":{"id":"/docs/modules/multi-head-latent-attention-9","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-8","content":"Limitations And Tradeoffs"},"1433":{"id":"/docs/modules/multi-head-latent-attention-10","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-9","content":"Why It Still Matters"},"1434":{"id":"/docs/modules/multi-head-latent-attention-11","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-10","content":"Related"},"1435":{"id":"/docs/modules/multi-head-latent-attention-12","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-11","content":"Tags"},"1436":{"id":"/docs/modules/multi-head-latent-attention-13","page_id":"/docs/modules/multi-head-latent-attention","type":"heading","tags":["attention","kv-cache"],"url":"/docs/modules/multi-head-latent-attention#heading-12","content":"References"},"1437":{"id":"/docs/modules/multi-head-latent-attention-14","page_id":"/docs/modules/multi-head-latent-attention","tags":["attention","kv-cache"],"type":"text","url":"/docs/modules/multi-head-latent-attention#Multi-Head Latent Attention","content":"An attention variant that compresses key-value cache storage into a low-rank latent space while keeping distinct query heads.\n\nMulti-Head Latent Attention\nAn attention variant that compresses key-value cache storage into a low-rank latent space while keeping distinct query heads.\nKV caches grow with context length and head dimension, raising memory use during long-context inference; multi-head latent attention (MLA) stores a compact latent KV representation and reconstructs per-head keys and values on demand so the cache holds fewer bytes without collapsing to a single shared head.\nWhat It Is\nMulti-head latent attention is an attention variant derived from multi-head attention. It keeps multiple query heads but projects keys and values into a shared low-rank latent space that is cached during autoregressive decoding.\nWhat It Optimizes\nMLA targets KV-cache footprint, memory bandwidth during autoregressive decoding, and the cost of serving long contexts when full per-head KV tensors would otherwise dominate memory.\nPractical Benefit\nTeams adopt MLA when they need multi-head query expressiveness but want a smaller inference cache than full multi-head attention. MLA compresses stored KV state more aggressively than grouped-query or multi-query sharing alone by caching a latent representation instead of full head tensors.\nHow It Works\nKeys and values are down-projected into a latent KV cache with rank r. During attention, latent vectors are up-projected back to per-head key and value spaces. Queries remain head-specific, so each head attends against reconstructed KV pairs derived from the shared latent cache.\nMath Or Compute Schema\nWith H query heads and latent rank r, MLA caches compact latent KV vectors and reconstructs per-head keys and values through low-rank projections. The formulas below contrast full multi-head attention against MLA, which routes queries through a shared latent cache.\nCompared To Nearby Modules\nCompared with multi-head attention, MLA stores a compressed latent cache instead of full per-head KV tensors. Compared with multi-query and grouped-query attention, MLA keeps distinct query heads while compressing KV state through low-rank projection rather than only sharing heads.\nExample Architectures\nMLA appears in large decoder-only language models that prioritize efficient long-context inference while retaining multi-head query pathways.\nLimitations And Tradeoffs\nLow-rank KV compression can limit representational flexibility versus storing full per-head tensors. The optimal latent rank depends on model scale and quality targets.\nWhy It Still Matters\nAs context windows grow, KV-cache efficiency remains a first-order serving constraint, so MLA offers a path between MHA fidelity and aggressive cache compression through latent storage.\nRelated\nTags\nReferences\nMulti-head attention versus multi-head latent attention KV-cache comparison\nToggle MHA and MLA to compare full per-head KV storage against compressed latent KV caching on one canvas\nHow MLA compares with nearby attention variants"},"1438":{"id":"/docs/modules/multi-head-latent-attention-15","page_id":"/docs/modules/multi-head-latent-attention","tags":["attention","kv-cache"],"type":"text","url":"/docs/modules/multi-head-latent-attention","content":"MLA"},"1439":{"id":"/docs/modules/multi-head-latent-attention-16","page_id":"/docs/modules/multi-head-latent-attention","tags":["attention","kv-cache"],"type":"text","url":"/docs/modules/multi-head-latent-attention","content":"multi-head latent attention"},"1440":{"id":"/docs/modules/multi-head-latent-attention-17","page_id":"/docs/modules/multi-head-latent-attention","tags":["attention","kv-cache"],"type":"text","url":"/docs/modules/multi-head-latent-attention","content":"multi head latent attention"},"1441":{"id":"/docs/modules/multi-head-latent-attention-18","page_id":"/docs/modules/multi-head-latent-attention","tags":["attention","kv-cache"],"type":"text","url":"/docs/modules/multi-head-latent-attention","content":"attention"},"1442":